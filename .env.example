# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DOCS_URL=http://localhost:4002

# ─── Main app (app/app) ───────────────────────────────────────────────────────
# Used for: redirecting to login, token refresh, user profile fetch, logout
NEXT_PUBLIC_APP_URL=http://localhost:4000

# ─── Cross-app auth session ───────────────────────────────────────────────────
# Production should use a secure parent domain, for example .gracon360.com, so
# app.gracon360.com login can be reused by documents.gracon360.com.
NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=
NEXT_PUBLIC_AUTH_COOKIE_SECURE=false
NEXT_PUBLIC_AUTH_COOKIE_SAME_SITE=lax
NEXT_PUBLIC_AUTH_SESSION_HINT_COOKIE_NAME=session_active
NEXT_PUBLIC_AUTH_ACCESS_COOKIE_NAME=g360_at
NEXT_PUBLIC_AUTH_REFRESH_COOKIE_NAME=g360_rt

# Must match app/app and the auth service. Access tokens should remain short;
# refresh/session tokens can be 1d if daily re-authentication is required.
NEXT_PUBLIC_AUTH_ACCESS_TOKEN_TTL=15m
NEXT_PUBLIC_AUTH_REFRESH_TOKEN_TTL=1d

# Development compatibility only. Keep local documents login/readable cookies
# available in dev, but use app/app login and server-owned cookies in production.
# Development path remains intact with NEXT_PUBLIC_ALLOW_DEV_READABLE_AUTH_COOKIES=true.
# Production should use:
# NEXT_PUBLIC_ALLOW_DEV_READABLE_AUTH_COOKIES=false
# NEXT_PUBLIC_DOCUMENTS_USE_MAIN_APP_LOGIN=true
# parent cookie domain like .gracon360.com
NEXT_PUBLIC_DOCUMENTS_USE_MAIN_APP_LOGIN=false
NEXT_PUBLIC_ALLOW_DEV_READABLE_AUTH_COOKIES=true

# Server-side production auth policy. Use these in .env.production so route
# handlers do not need to rely on NEXT_PUBLIC values for sensitive cookie setup.
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=1d
AUTH_REFRESH_ROTATION=true
AUTH_REUSE_DETECTION=true
DOCUMENTS_USE_MAIN_APP_LOGIN=false
ALLOW_DEV_READABLE_AUTH_COOKIES=true

# ─── API services ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTH_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_DOCS_API_URL=http://localhost:3005/api/v1
NEXT_PUBLIC_SIGNATURE_API_URL=http://localhost:3002/api/v1

# Base URL of the documents frontend (used in PDF QR codes)
DOCS_BASE_URL=https://your-docs-domain.com
